# Copy to .env.local and fill from your Convex dashboard (Settings → URL & Deploy Key).
VITE_CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud
# Must be the .convex.site URL (not .convex.cloud).
VITE_CONVEX_SITE_URL=https://YOUR_DEPLOYMENT.convex.site
# Optional: Nitro/SSR can also read these names (same values as above).
# CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud
# CONVEX_SITE_URL=https://YOUR_DEPLOYMENT.convex.site
# Same URL you open in the browser (must match npx convex env set SITE_URL ...).
VITE_SITE_URL=http://localhost:3000
